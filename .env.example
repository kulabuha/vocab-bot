# Copy to .env and fill in. Do not commit .env with real secrets.
# For VPS/production: use external LLM (OpenAI or compatible API). See docs/DEPLOYMENT.md.

TELEGRAM_BOT_TOKEN=

# --- External LLM (production / VPS) ---
# OpenAI or any OpenAI-compatible API (Azure, Groq, Together, etc.)
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# --- Local LLM (Ollama) for development only ---
# On host: ollama pull llama3.2:3b  (see docs/LLM.md)
# LLM_API_BASE=http://host.docker.internal:11434/v1
# LLM_API_KEY=
# LLM_MODEL=llama3.2:3b

LLM_TIMEOUT_SEC=60

# Optional: append error-level logs to this file (JSON lines). Leave empty to log only to stderr.
# With Docker use a path inside the mounted volume so the file exists and is writable, e.g.:
# ERROR_LOG_PATH=/data/errors.log
ERROR_LOG_PATH=

# Optional: per-user usage stats (add/train/answer counts, last request) written to this JSON file.
# With Docker use a path inside the mounted volume, e.g.:
# STATS_FILE_PATH=/data/stats.json
STATS_FILE_PATH=
