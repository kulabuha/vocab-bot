# MCP HTTP API (optional service)
FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /mcp ./cmd/mcp

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /mcp .
ENV DB_PATH=/data/app.db
ENV MCP_PORT=8080
VOLUME /data
EXPOSE 8080
ENTRYPOINT ["./mcp"]